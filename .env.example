# Control service
PLUME_CONTROL_HOST=0.0.0.0
PLUME_CONTROL_PORT=8000
PLUME_CONTROL_RELOAD=false

# Frontend/API URL
VITE_API_BASE_URL=http://localhost:8000
VITE_OPS_API_TOKEN=

# Artifact and job stores
PLUME_ARTIFACT_DIR=artifacts
PLUME_FORECAST_JOBS_PATH=artifacts/forecast_jobs/forecast_jobs.json

# Session state
PLUME_STATE_STORE=in_memory
PLUME_SESSION_STORE_DIR=artifacts/session_store

# Ops/retraining stores
PLUME_OPS_DIR=artifacts/convlstm_ops
PLUME_OPS_AUTO_DISPATCH_WORKER=false

# Explanation artifacts
PLUME_PERSIST_BATCH_EXPLANATION=false
PLUME_PERSIST_BATCH_EXPLANATION_USE_LLM=false

# OpenRemote integration
PLUME_OPENREMOTE_SERVICE_REGISTRATION_ENABLED=false
PLUME_OPENREMOTE_ENABLED=false
PLUME_OPENREMOTE_SINK_MODE=disabled
PLUME_OPENREMOTE_MANAGER_API_URL=
PLUME_OPENREMOTE_SERVICE_HOMEPAGE_URL=
PLUME_OPENREMOTE_FORECAST_ASSET_ID=
